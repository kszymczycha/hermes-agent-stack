# =============================================================================
# Hermes Agent — environment variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control (add it to .gitignore).
# =============================================================================

# -----------------------------------------------------------------------------
# Host data directory (default: ~/.hermes)
# -----------------------------------------------------------------------------
HERMES_DATA_DIR=~/.hermes

# -----------------------------------------------------------------------------
# Dashboard authentication (username/password)
# -----------------------------------------------------------------------------
HERMES_DASHBOARD_USER=
HERMES_DASHBOARD_PASSWORD=
# Generate a secret: openssl rand -hex 32
HERMES_DASHBOARD_SECRET=

# -----------------------------------------------------------------------------
# LLM API keys
# You can also place these directly in ~/.hermes/.env
# -----------------------------------------------------------------------------
# ANTHROPIC_API_KEY=

# -----------------------------------------------------------------------------
# Chat platform tokens (optional)
# -----------------------------------------------------------------------------
TELEGRAM_BOT_TOKEN=
TELEGRAM_ALLOWED_USERS=
# DISCORD_BOT_TOKEN=
# SLACK_BOT_TOKEN=

# Google Gemini
# Get your free API key: https://aistudio.google.com/apikey
# Available models: gemini-3.5-flash, gemini-3.1-flash-lite, gemini-2.5-flash
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=
# HERMES_MODEL_PROVIDER=
# HERMES_MODEL=

# -----------------------------------------------------------------------------
# Gateway API server key (optional)
# Generate: openssl rand -hex 32
# -----------------------------------------------------------------------------
# API_SERVER_KEY=
